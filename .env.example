# Unpooled: usada por migrations e seed
DATABASE_URL_UNPOOLED=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# E-mail de confirmação (SMTP do Gmail via Nodemailer). Opcional: sem estas,
# o agendamento funciona normalmente e o envio é apenas pulado.
# SMTP_USER = seu Gmail; SMTP_PASSWORD = App Password de 16 dígitos
# (Conta Google > Segurança > Verificação em duas etapas > Senhas de app).
SMTP_USER=""
SMTP_PASSWORD=""
# Opcionais (padrões: smtp.gmail.com / 465):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# Remetente exibido. Use o mesmo endereço do SMTP_USER.
MAIL_FROM="LavaÁgil <seu-email@gmail.com>"